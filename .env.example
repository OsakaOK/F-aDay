# Leave DATABASE_URL unset for local development — the app falls back to an
# embedded PGlite database persisted under ./.pglite (no external service needed).
#
# In production (Vercel), set DATABASE_URL to your Postgres connection string
# (Supabase or Neon). When set, the app uses node-postgres instead of PGlite.
# DATABASE_URL=postgres://user:password@host:5432/dbname
